{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/session_breath.py\"",
            "timeout": 12,
            "statusMessage": "Ombre Brain 正在浮现记忆..."
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/session_breath.py\"",
            "timeout": 12,
            "statusMessage": "Ombre Brain 正在浮现记忆..."
          }
        ]
      }
    ]
  }
}
